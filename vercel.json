{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --include=dev",
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://*.maptiler.com https://*.openstreetmap.org; connect-src 'self' data: https://*.maptiler.com https://api.open-meteo.com https: wss:; worker-src 'self' blob:; child-src blob:; frame-ancestors 'none'"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/business",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/business/(.*)",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/tech",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/tech/(.*)",
      "destination": "/",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
