  "process_stages": [
    {
      "id": "stage_feed_prep",
      "order": 1,
      "label": "Feed preparation (scrubbing)",
      "process_area": "feed_prep",
      "description": "Ionic clay ore is received, weighed, and scrubbed to remove organics and prepare slurry for leaching.",
      "inputs": [
        { "material": "ionic_clay_ore", "source_refs": ["WEBLINK-02969114"] }
      ],
      "outputs": [
        { "material": "clay_slurry", "source_refs": ["WEBLINK-02969114"] }
      ],
      "equipment": [],
      "source_refs": ["WEBLINK-02969114", "WEBLINK-02969122"]
    },
    {
      "id": "stage_leach",
      "order": 2,
      "label": "Ammonium sulfate leach",
      "process_area": "leach",
      "description": "Clay slurry is leached with ammonium sulfate solution at controlled pH (4.0–5.0) to extract rare earth ions via ion exchange.",
      "inputs": [
        { "material": "clay_slurry", "source_refs": ["WEBLINK-02969114"] },
        { "material": "ammonium_sulfate_solution", "source_refs": ["WEBLINK-02969114"] }
      ],
      "outputs": [
        { "material": "pregnant_liquor", "source_refs": ["WEBLINK-02969114"] },
        { "material": "spent_clay", "source_refs": ["WEBLINK-02969114"] }
      ],
      "equipment": [],
      "source_refs": ["WEBLINK-02969114", "WEBLINK-02969122"]
    },
    {
      "id": "stage_precipitation",
      "order": 3,
      "label": "MREC precipitation",
      "process_area": "precipitation",
      "description": "Pregnant liquor undergoes precipitation to produce mixed rare earth carbonate (MREC) solids.",
      "inputs": [
        { "material": "pregnant_liquor", "source_refs": ["WEBLINK-02969114"] }
      ],
      "outputs": [
        { "material": "mrec_solids", "source_refs": ["WEBLINK-02969114"] },
        { "material": "barren_liquor", "source_refs": ["WEBLINK-02969114"] }
      ],
      "equipment": [],
      "source_refs": ["WEBLINK-02969114"]
    },
    {
      "id": "stage_solid_liquid_sep",
      "order": 4,
      "label": "Solid/liquid separation (dewatering)",
      "process_area": "solid_liquid_separation",
      "description": "MREC solids are separated from liquor via filtration and dewatering for packaging.",
      "inputs": [
        { "material": "mrec_solids", "source_refs": ["WEBLINK-02969114"] }
      ],
      "outputs": [
        { "material": "mrec_product", "source_refs": ["WEBLINK-02969114"] },
        { "material": "filtrate", "source_refs": ["WEBLINK-02969114"] }
      ],
      "equipment": [],
      "source_refs": ["WEBLINK-02969114"]
    },
    {
      "id": "stage_reagent_recovery",
      "order": 5,
      "label": "Reagent recovery (AMSUL)",
      "process_area": "reagent_recovery",
      "description": "Spent ammonium sulfate solution is recovered and recycled back to the leach circuit (~90% recovery).",
      "inputs": [
        { "material": "barren_liquor", "source_refs": ["WEBLINK-02969114"] }
      ],
      "outputs": [
        { "material": "recycled_ammonium_sulfate", "source_refs": ["WEBLINK-02969114"] }
      ],
      "equipment": [],
      "source_refs": ["WEBLINK-02969114"]
    },
    {
      "id": "stage_water_treatment",
      "order": 6,
      "label": "Water treatment and recycling",
      "process_area": "utilities",
      "description": "Process water is treated and recycled (~85% recirculation target) to minimize freshwater intake.",
      "inputs": [
        { "material": "process_water", "source_refs": ["WEBLINK-02969114"] },
        { "material": "filtrate", "source_refs": ["WEBLINK-02969114"] }
      ],
      "outputs": [
        { "material": "recycled_water", "source_refs": ["WEBLINK-02969114"] }
      ],
      "equipment": [],
      "source_refs": ["WEBLINK-02969114"]
    },
    {
      "id": "stage_material_handling",
      "order": 7,
      "label": "Material handling and spent clay disposal",
      "process_area": "material_handling",
      "description": "Spent clay from leaching is neutralized and managed according to environmental permit conditions.",
      "inputs": [
        { "material": "spent_clay", "source_refs": ["WEBLINK-02969114"] }
      ],
      "outputs": [
        { "material": "neutralized_clay", "source_refs": ["WEBLINK-02969114"] }
      ],
