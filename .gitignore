# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# TypeScript build artifacts in shared/ (source of truth is .ts)
shared/**/*.js
shared/**/*.d.ts
shared/**/*.js.map

# Playwright outputs (results are ephemeral; snapshots under e2e/*-snapshots/ stay tracked)
playwright-report/
test-results/

# SQLite database (generated at runtime by the server)
*.db
*.db-shm
*.db-journal
*.db-wal

# Environment variables (contains API keys)
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.cursor/*
!.cursor/rules/
.cursor/rules/*
!.cursor/rules/delegation-preference.mdc
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel
