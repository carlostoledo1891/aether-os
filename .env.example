# ─── Data Mode ────────────────────────────────────────────────────────────
# 'mock'  → standalone frontend, no server needed, all data is client-generated
# 'live'  → frontend calls Fastify server (real enricher data, WebSocket telemetry)
VITE_DATA_MODE=live

# ─── Site Password Gate ───────────────────────────────────────────────────
# Protects all pages with a client-side password prompt (24h session).
# Generate a new one with: openssl rand -hex 6
# If unset, falls back to the hardcoded default in PasswordGate.tsx.
# VITE_SITE_PASSWORD=your-password-here

# ─── Frontend (Vite) ──────────────────────────────────────────────────────

# MapTiler API Key — free tier at https://maptiler.com (100K requests/month)
VITE_MAPTILER_KEY=

# OpenWeatherMap tile key — optional, for cloud/radar overlay tiles
# VITE_OWM_KEY=

# Project ID — determines tenant config, map center, available views (default: caldeira)
VITE_PROJECT_ID=caldeira

# Backend URLs
# - Local dev: leave both empty and use the Vite proxy (`npm run dev:all`).
# - Hosted staging/prod: set `VITE_API_BASE_URL` to the Railway/hosted API origin.
# - `VITE_WS_URL` is optional when it matches the API origin; the app derives it from
#   `VITE_API_BASE_URL` automatically. Set it explicitly only when websockets live elsewhere.
# VITE_API_BASE_URL=https://staging-api.example.com
# VITE_WS_URL=wss://staging-api.example.com/ws

# Stakeholder demo: tighter honesty banner + provenance emphasis
# VITE_PRESENTATION_MODE=1

# IR disclosure mode: hides simulated telemetry, shows board-approved facts only
# VITE_DISCLOSURE_MODE=1

# Feature flags — set to 0 to disable (all enabled by default)
# VITE_FEATURE_CHAT=1
# VITE_FEATURE_REPORTS=1
# VITE_FEATURE_CONTROL_ROOM=1
# VITE_FEATURE_AI_AGENT=1
# VITE_FEATURE_ALERTS=1
# VITE_FEATURE_MAP_SATELLITE=1

# ─── Weather (browser-side, works in both mock and live mode) ─────────────
# When enabled, fetches from Open-Meteo (free) and BrasilAPI/CPTEC.
# In 'live' mode with server running, prefers server-side enricher data.
VITE_WEATHER_ENABLED=true
VITE_WEATHER_LAT=-21.84
VITE_WEATHER_LNG=-46.555

# ─── Server (Fastify) ────────────────────────────────────────────────────

# Port for the Aether API server (default: 3001)
# PORT=3001
# HOST=0.0.0.0

# SQLite database path (default: <server-root>/data/aether.db)
# The server auto-creates the parent directory if missing.
# In Docker/Railway, defaults to /data/aether.db via Dockerfile ENV.
# DB_PATH=/data/aether.db

# CORS origin restriction (default: allow all in dev)
# Set to your Vercel domain in production
# CORS_ORIGIN=https://your-app.vercel.app

# Shared secret for /ingest/* endpoints
# Generate with: openssl rand -hex 32
# When empty, the guard is skipped (local dev stays frictionless)
# INGEST_API_KEY=

# Admin API key for knowledge base management endpoints
# When empty, the guard is skipped (local dev stays frictionless)
# ADMIN_API_KEY=

# ─── Chat API Key (must match CHAT_API_KEY on the server/Railway) ─────────
# When set, the frontend sends this as x-api-key header on /api/chat requests.
# Generate with: openssl rand -hex 32
# VITE_CHAT_API_KEY=

# ─── AI Agent (Vero AI — LLM via Vercel AI SDK, model-agnostic) ─────────

# Google Generative AI API key — free tier: 15 RPM, 1M tokens/min
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Model ID — default: gemini-2.5-flash (model-agnostic, swap provider via @ai-sdk/*)
# Swap to e.g. gpt-4o (via @ai-sdk/openai) or claude-sonnet-4-20250514 (via @ai-sdk/anthropic)
# AI_MODEL=gemini-2.5-flash

# ─── Engine (Vero Simulation Engine) ─────────────────────────────────────

# API URL the engine pushes to (default: http://localhost:3001)
# In Railway, use internal networking: http://aether-api.railway.internal:3001
# AETHER_API_URL=http://localhost:3001

# Tick interval in ms (default: 2000)
# TICK_MS=2000

# Site coordinates for weather/seismic enrichers
SITE_LAT=-21.84
SITE_LNG=-46.555

# ─── Engine Enrichers ─────────────────────────────────────────────────────
# Each enricher fetches from a free public API and pushes to the server DB.
# Set to 0 to disable specific enrichers.
ENRICHER_OPENMETEO=1
ENRICHER_BCB=1
ENRICHER_USGS=1
ENRICHER_FORECAST=1
ENRICHER_ARCHIVE=1

# Alpha Vantage (free key from https://www.alphavantage.co/support/#api-key)
# Enables MEI.AX stock quote enricher (25 requests/day free)
# ALPHA_VANTAGE_KEY=
