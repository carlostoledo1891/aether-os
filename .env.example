# ─── Frontend (Vite) ──────────────────────────────────────────────────────

# MapTiler API Key — free tier at https://maptiler.com (100K requests/month)
VITE_MAPTILER_KEY=

# Data mode: 'mock' (client-side generation) or 'live' (real backend API + WebSocket)
# Set to 'live' when running with the Aether API server.
VITE_DATA_MODE=live

# Backend URLs (leave empty when using Vite proxy in dev — it forwards /api/* and /ws/*)
# Only set these for production deployments where frontend and API are on different origins.
# VITE_API_BASE_URL=https://api.example.com
# VITE_WS_URL=wss://api.example.com/ws

# Stakeholder demo: tighter honesty banner + provenance emphasis
# VITE_PRESENTATION_MODE=1

# IR disclosure mode: hides simulated telemetry, shows board-approved facts only
# VITE_DISCLOSURE_MODE=1

# Client-side weather (Hydro Twin) — only used when VITE_DATA_MODE=mock
# When running live, weather comes from the engine's Open-Meteo enricher.
# VITE_WEATHER_ENABLED=1
# VITE_WEATHER_LAT=-21.815
# VITE_WEATHER_LNG=-46.585

# ─── Server (Fastify) ────────────────────────────────────────────────────

# Port for the Aether API server (default: 3001)
# PORT=3001
# HOST=0.0.0.0

# SQLite database path (default: <server-root>/aether.db)
# Set to a persistent volume path in production (e.g. /data/aether.db on Railway)
# DB_PATH=/data/aether.db

# CORS origin restriction (default: allow all in dev)
# Set to your Vercel domain in production
# CORS_ORIGIN=https://your-app.vercel.app

# Shared secret for /ingest/* endpoints
# Generate with: openssl rand -hex 32
# When empty, the guard is skipped (local dev stays frictionless)
# INGEST_API_KEY=

# ─── AI Agent (Vero AI — Gemini via Vercel AI SDK) ──────────────────────

# Google Generative AI API key — free tier: 15 RPM, 1M tokens/min
# Get one at https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=

# Model ID — default: gemini-2.5-flash-preview-04-17
# Swap to e.g. gpt-4o (via @ai-sdk/openai) or claude-sonnet-4-20250514 (via @ai-sdk/anthropic)
# AI_MODEL=gemini-2.5-flash-preview-04-17

# ─── Engine (Vero Simulation Engine) ─────────────────────────────────────

# API URL the engine pushes to (default: http://localhost:3001)
# In Railway, use internal networking: http://aether-api.railway.internal:3001
# AETHER_API_URL=http://localhost:3001

# Tick interval in ms (default: 2000)
# TICK_MS=2000

# Site coordinates for weather/seismic enrichers
# SITE_LAT=-21.815
# SITE_LNG=-46.585

# Disable specific enrichers (set to 0 to disable)
# ENRICHER_OPENMETEO=1
# ENRICHER_BCB=1
# ENRICHER_USGS=1

# Alpha Vantage (free key from https://www.alphavantage.co/support/#api-key)
# Set to enable MEI.AX stock quote enricher (25 requests/day free)
# ALPHA_VANTAGE_KEY=
